# Copy to .env and fill in real values. Never commit .env.
# Referenced from default_workspace/config.user.yaml via ${VAR_NAME} substitution.

# Fireworks AI
FIREWORKS_API_KEY=fw-your-fireworks-api-key-here
# FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
# ALLOWED_MODELS=fireworks_ai/accounts/fireworks/models/deepseek-v4-flash,fireworks_ai/accounts/fireworks/models/kimi-k2p7-code

# OpenAI (only if llm.provider: openai)
# OPENAI_API_KEY=sk-your-openai-api-key-here

# Web search / channels (optional, uncomment matching config in config.user.yaml)
# BRAVE_API_KEY=your-brave-search-api-key
# TELEGRAM_BOT_TOKEN=your-telegram-bot-token
# DISCORD_BOT_TOKEN=your-discord-bot-token
